---
import { Icon } from "astro-icon/components";
import Card from "../temple/Card.astro";
---

<Card>
  <div class="p-4">
    <form action="/blog/search" method="get" class="relative w-full">
      <div class="search-container w-full relative">
        <input
          type="text"
          name="q"
          placeholder="搜索"
          class="input input-bordered liquid-input w-full h-12 pl-4 pr-14 text-base"
          aria-label="搜索"
        />
        <button
          type="submit"
          class="absolute right-2 top-1/2 -translate-y-1/2 h-8 w-8 rounded-lg liquid-action-btn sidebar-search-submit flex items-center justify-center"
          aria-label="搜索"
        >
          <Icon name="lucide:search" class="w-4 h-4" />
        </button>
      </div>
    </form>
  </div>
</Card>

<script>
  // Focus search input when pressing '/' key
  document.addEventListener("keydown", (e) => {
    const target = e.target as HTMLElement;
    if (e.key === "/" && target && target.tagName !== "INPUT" && target.tagName !== "TEXTAREA") {
      e.preventDefault();
      const searchInput = document.querySelector('input[name="q"]');
      if (searchInput) {
        (searchInput as HTMLInputElement).focus();
      }
    }
  });
</script>

<style is:inline>
  .search-container {
    position: relative;
  }

  .sidebar-search-submit {
    position: absolute !important;
    right: 0.5rem !important;
    left: auto !important;
    top: 50% !important;
    bottom: auto !important;
    transform: translateY(-50%) !important;
    z-index: 2;
  }
</style>
